{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "JwtSettings": {
    "Issuer": "CoupleHub.Identity",
    "Audience": "CoupleHub.Apps",
    "SecretKey": "SUA_CHAVE_SECRETA_SUPER_SEGURA_COM_PELO_MENOS_256_BITS_AQUI"
  },
  "Microservices": {
    "IdentityUrl": "http://localhost:5013",
    "TasksUrl": "http://localhost:5002",
    "MatchUrl": "http://localhost:5003"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/v1/auth/{**catch-all}"
        }
      },
      "tasks-route": {
        "ClusterId": "tasks-cluster",
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "FixedWindow",
        "Match": {
          "Path": "/v1/tasks/{**catch-all}"
        }
      },
      "match-hub-route": {
        "ClusterId": "match-hub-cluster",
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "FixedWindow",
        "Match": {
          "Path": "/hubs/match/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-instancia-1": {
            "Address": "http://localhost:5013"
          }
        }
      },
      "tasks-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "tasks-instancia-1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "match-hub-cluster": {
        "SessionAffinity": {
          "Enabled": true,
          "Policy": "Cookie",
          "FailurePolicy": "Redistribute",
          "AffinityKeyName": "Name"
        },
        "Destinations": {
          "match-instancia-1": {
            "Address": "http://localhost:5003"
          }
        }
      }
    }
  }
}