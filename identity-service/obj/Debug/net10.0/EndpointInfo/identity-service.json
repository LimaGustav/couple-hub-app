{
  "openapi": "3.1.1",
  "info": {
    "title": "identity-service | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5013"
    }
  ],
  "paths": {
    "/v1/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "operationId": "RegisterUser",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterUserRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "operationId": "Login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/couples": {
      "post": {
        "tags": [
          "Couples"
        ],
        "operationId": "CreateCouple",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/couples/join": {
      "post": {
        "tags": [
          "Couples"
        ],
        "operationId": "JoinCouple",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinCoupleRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "JoinCoupleRequest": {
        "required": [
          "partnerUsername",
          "coupleId"
        ],
        "type": "object",
        "properties": {
          "partnerUsername": {
            "type": [
              "null",
              "string"
            ]
          },
          "coupleId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "username",
          "password"
        ],
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterUserRequest": {
        "required": [
          "username",
          "password",
          "name",
          "birthday"
        ],
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "birthday": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Couples"
    }
  ]
}